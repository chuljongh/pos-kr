{
  "cleanUrls": true,
  "trailingSlash": false,
  "redirects": [
    {
      "source": "/hamba",
      "destination": "/",
      "permanent": true
    },
    {
      "source": "/cafe/:path*",
      "destination": "https://cafe.pos.kr",
      "permanent": true
    },
    {
      "source": "/cafe",
      "destination": "https://cafe.pos.kr",
      "permanent": true
    },
    {
      "source": "/:path*",
      "has": [
        {
          "type": "host",
          "value": "www.pos.kr"
        }
      ],
      "destination": "https://pos.kr/:path*",
      "permanent": true
    }
  ]
}
